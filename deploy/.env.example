# --- Per-store stack (.env for deploy/docker-compose.yml) ---
# Generate UNIQUE values per store. Never reuse across tenants.

# Image to deploy (set to a pinned tag in production, not :latest)
STRAPI_IMAGE=ghcr.io/khalildaibes/ecomstrapi:latest

# Database
DATABASE_NAME=ecommerce_strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=CHANGE_ME_unique_per_store
DATABASE_SSL=false

# Strapi secrets — generate per store:
#   APP_KEYS:  4x `openssl rand -base64 32` joined by commas
#   others:    openssl rand -base64 32
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=CHANGE_ME
ADMIN_JWT_SECRET=CHANGE_ME
TRANSFER_TOKEN_SALT=CHANGE_ME
JWT_SECRET=CHANGE_ME

# n8n (Telegram/AI automation)
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_unique_per_store
N8N_SECURE_COOKIE=false
TZ=Asia/Jerusalem

# AI keys for the automation workflows
OPENAI_API_KEY=
GEMINI_API_KEY=
